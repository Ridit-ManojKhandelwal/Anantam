{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "outDir": "dist",
    "moduleResolution": "node",
    // "resolveJsonModule": true,
    // "strict": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["DOM", "ESNext"],
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": ["src/**/*"]
}
